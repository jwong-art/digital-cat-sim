}

// ==================== 随机事件 ====================
let pendingEvent = null;

function showRandomEvent(event) {
    if (!event) return;
    pendingEvent = event;

    const popup = document.getElementById('eventPopup');
    const iconEl = document.getElementById('eventIcon');
    const nameEl = document.getElementById('eventName');
    const descEl = document.getElementById('eventDesc');
    const effectsEl = document.getElementById('eventEffects');

    popup.className = 'event-popup ' + event.category;

    iconEl.textContent = event.icon;
    nameEl.textContent = event.name;
    descEl.textContent = event.description;

    let effectsHtml = '';
    if (event.effects) {
        const labels = {
            hunger: '饥饿', thirst: '口渴', sleep: '睡眠', happy: '快乐',
            cleanliness: '清洁', money: '金钱'
        };
        for (const [key, value] of Object.entries(event.effects)) {
            if (value === 0) continue;
            const label = labels[key] || key;
            const cls = value > 0 ? 'positive' : 'negative';
            const sign = value > 0 ? '+' : '';
            effectsHtml += `<span class="${cls}">${label} ${sign}${value}</span>`;
        }
    }
    effectsEl.innerHTML = effectsHtml;

    popup.classList.add('show');
    setTimeout(() => closeRandomEvent(), 4000);
}

function closeRandomEvent() {
    const popup = document.getElementById('eventPopup');
    popup.classList.remove('show');
    pendingEvent = null;
}

// ==================== 猫咪心情系统 ====================
function getCatMood(state) {
    if (!state) return { emoji: '😺', text: '普通', class: 'mood-neutral' };

    const avg = (state.hunger + state.thirst + state.sleep + state.happy + state.cleanliness) / 5;

    if (state.isSick) return { emoji: '🤒', text: '生病', class: 'mood-miserable' };
    if (avg >= 90) return { emoji: '😻', text: '超开心', class: 'mood-happy' };
    if (avg >= 70) return { emoji: '😺', text: '开心', class: 'mood-content' };
    if (avg >= 50) return { emoji: '🐱', text: '一般', class: 'mood-neutral' };
    if (avg >= 30) return { emoji: '😿', text: '不开心', class: 'mood-sad' };
    return { emoji: '🙀', text: '很难受', class: 'mood-miserable' };
}

function updateCatMood() {
    const mood = getCatMood(catState);

    const indicator = document.getElementById('moodIndicator');
    if (indicator) {
        indicator.textContent = mood.emoji;
        indicator.className = 'mood-indicator ' + mood.class;
    }

    updateCatEyes(mood);
}

function updateCatEyes(mood) {
    const catSvg = document.getElementById('catSvg');
    if (!catSvg) return;

    const eyes = catSvg.querySelectorAll('.cat-eye');
    if (eyes.length < 2) return;

    switch (mood.class) {
        case 'mood-happy':
            eyes.forEach(eye => eye.setAttribute('ry', '3'));
            break;
        case 'mood-miserable':
            eyes.forEach(eye => eye.setAttribute('ry', '7'));
            break;
        default:
            eyes.forEach(eye => eye.setAttribute('ry', '6'));
    }
}

// ==================== 初始化 ====================
async function initFeatures() {
    // 1. 立即渲染房间（同步，不依赖API）
    rooms = Object.entries(ROOM_CONFIG).map(([id, config]) => ({
        id: id,
        name: config.name,
        icon: config.icon,
        description: config.description
    }));
    renderRoomTabs();
    renderRoomScene();
    updateActionButtons();
    updateCatMood();
    
    // 2. 后台加载API数据
    loadAchievements();
    loadStatistics();
    loadRooms();
}

// 点击弹窗外部关闭（直接执行，不需要等 DOMContentLoaded，因为 features.js 在 body 末尾加载时 DOM 已就绪）
if (document.getElementById('achievementModal')) {
    document.getElementById('achievementModal').addEventListener('click', (e) => {
        if (e.target.id === 'achievementModal') closeAchievementModal();
    });
}
if (document.getElementById('statsModal')) {
    document.getElementById('statsModal').addEventListener('click', (e) => {
        if (e.target.id === 'statsModal') closeStatsModal();
    });
}

// 将 switchRoom 暴露到 window 对象
window.__switchRoom = switchRoom;