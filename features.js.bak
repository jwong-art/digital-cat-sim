let currentRoom = 'living_room';
let rooms = [];

async function loadRooms() {
    try {
        const result = await apiRequest('rooms');
        if (result && result.success && result.currentRoom) {
            currentRoom = result.currentRoom;
            renderRoomTabs();
            renderRoomScene();
            updateActionButtons();
        }
    } catch(e) {
        console.warn('获取房间状态失败:', e);
    }
}

function renderRoomTabs() {
    const container = document.getElementById('roomTabs');
    if (!container) return;

    container.innerHTML = rooms.map(room => {
        const config = ROOM_CONFIG[room.id];
        if (!config) return '';
        return `
            <div class="room-tab ${room.id === currentRoom ? 'active' : ''}"
                 data-room="${room.id}" title="${room.description}">
                <div class="room-tab-icon">${config.icon}</div>
                <div class="room-tab-name">${config.name}</div>
            </div>
        `;
    }).join('');
    
    // 事件委托：点击标签切换房间
    container.querySelectorAll('.room-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            const roomId = tab.getAttribute('data-room');
            if (roomId) switchRoom(roomId);
        });
    });
}

function renderRoomScene() {
    const config = ROOM_CONFIG[currentRoom];
    if (!config) return;

    // 1. 更新背景
    const roomBg = document.querySelector('.room-bg');
    if (roomBg) {
        roomBg.className = 'room-bg ' + config.bgClass;
    }

    // 2. 隐藏原始固定家具（客厅默认的）
    const staticFurniture = document.querySelectorAll('.furniture');
    staticFurniture.forEach(f => f.style.display = 'none');

    // 3. 渲染房间家具到动态容器
    const furnitureContainer = document.getElementById('furnitureContainer');
    if (furnitureContainer) {
        furnitureContainer.innerHTML = config.furniture.map(([emoji, cssClass, onclick, interactive]) => {
            const classes = `room-furniture ${cssClass} ${interactive ? 'interactive' : ''}`;
            return `<div class="${classes}" ${onclick ? `onclick="${onclick}"` : ''}>${emoji}</div>`;
        }).join('');

        // 重新添加购买的家具（如果有）
        if (typeof ownedFurniture !== 'undefined' && Array.isArray(ownedFurniture)) {
            ownedFurniture.forEach(f => addFurnitureToRoom(f.id));
        }
    }

    // 4. 处理睡觉场景
    const sleepingScene = document.getElementById('sleepingScene');
    if (sleepingScene) {
        const canSleep = (currentRoom === 'living_room' || currentRoom === 'bedroom' || currentRoom === 'garden');
        if (catState && catState.isSleeping && canSleep) {
            sleepingScene.classList.add('show');
        } else {
            sleepingScene.classList.remove('show');
        }
    }
}

async function switchRoom(roomId) {
    if (roomId === currentRoom) return;
    if (!catState) return;
    if (isBusy || catState.isSleeping || catState.isWorking || catState.isBathing) {
        showMoodBubble('🐱 忙碌中，无法换房间');
        return;
    }

    try {
        const result = await apiRequest('switch_room', { roomId });
        if (result && result.success) {
            currentRoom = roomId;
            catState = result.state;
            updateDisplay(result.state);
            renderRoomTabs();
            renderRoomScene();
            updateActionButtons();
            updateCatMood();
        } else if (result) {
            showMoodBubble('❌ ' + (result.message || '切换失败'));
        }
    } catch(e) {
        console.error('切换房间出错:', e);
        showMoodBubble('❌ 切换失败，请刷新页面');
    }
}

// 根据当前房间禁用/启用操作按钮
// 按钮最终状态 = 忙碌禁用 OR 房间禁用
function updateActionButtons() {
    const config = ROOM_CONFIG[currentRoom];
    if (!config) return;

    const allowedActions = config.actions;
    const isActionDisabled = catState.isSleeping || catState.isWorking || catState.isBathing;

    const actionButtons = {
        'eat': 'btnEat',
        'drink': 'btnDrink',
        'play': 'btnPlay',
        'sleep': 'btnSleep',
        'bathe': 'btnBathe',
        'work': 'btnWork',
        'study': 'btnStudy',
        'hospital': 'btnHospital'
    };

    for (const [action, btnId] of Object.entries(actionButtons)) {
        if (!btnId) continue;
        const btn = document.getElementById(btnId);
        if (!btn) continue;

        const isAllowed = allowedActions.includes(action);
        const isRoomDisabled = !isAllowed;

        // 先移除房间禁用样式
        btn.classList.remove('room-disabled');

        if (isRoomDisabled) {
            // 当前房间不允许此操作
            btn.classList.add('room-disabled');
            btn.disabled = true;
            btn.title = `当前房间（${config.name}）无法执行此操作`;
        } else {
            // 当前房间允许此操作，根据忙碌状态决定
            btn.title = '';
            // 特殊处理各按钮
            switch (action) {
                case 'sleep':
                    btn.disabled = catState.isWorking || catState.isBathing;
                    break;
                case 'bathe':
                    btn.disabled = isActionDisabled || (catState.cleanliness >= 100);
                    break;
                case 'hospital':
                    btn.disabled = isActionDisabled || !healthState.isSick;
                    break;
                default:
                    btn.disabled = isActionDisabled;
            }
        }
    }
}

// ==================== 成就系统 ====================
let achievements = [];

async function loadAchievements() {
    const result = await apiRequest('achievements');
    if (result && result.success) {
        achievements = result.achievements;
    }
}

function showAchievementModal() {
    const modal = document.getElementById('achievementModal');
    const container = document.getElementById('achievementItems');

    const unlocked = achievements.filter(a => a.unlocked).length;
    const total = achievements.length;

    document.getElementById('achievementCount').textContent = `${unlocked}/${total}`;

    const categories = {
        care: { name: '🐾 养育', items: [] },
        money: { name: '💰 经济', items: [] },
        study: { name: '📚 学习', items: [] },
        collect: { name: '🎒 收集', items: [] },
        special: { name: '⭐ 特殊', items: [] }
    };

    achievements.forEach(a => {
        if (categories[a.category]) {
            categories[a.category].items.push(a);
        }
    });

    let html = '';
    for (const [key, cat] of Object.entries(categories)) {
        if (cat.items.length === 0) continue;
        html += `<div style="margin: 10px 0 5px; font-size: 13px; color: #FFD700; font-weight: bold;">${cat.name}</div>`;
        cat.items.forEach(a => {
            html += `
                <div class="achievement-item ${a.unlocked ? 'unlocked' : 'locked'}">
                    <div class="achievement-icon">${a.unlocked ? a.icon : '🔒'}</div>
                    <div class="achievement-info">
                        <div class="achievement-name">${a.unlocked ? a.name : '???'}</div>
                        <div class="achievement-desc">${a.unlocked ? a.description : '未解锁'}</div>
                    </div>
                    <div class="achievement-status">${a.unlocked ? '✅' : ''}</div>
                </div>
            `;
        });
    }

    container.innerHTML = html;
    modal.classList.add('show');
}

function closeAchievementModal() {
    document.getElementById('achievementModal').classList.remove('show');
}

function showAchievementNotification(newAchievements) {
    if (!newAchievements || newAchievements.length === 0) return;

    newAchievements.forEach((a, index) => {
        setTimeout(() => {
            const notif = document.getElementById('achievementNotif');
            notif.innerHTML = `${a.icon} 成就解锁：${a.name}`;
            notif.classList.add('show');
            setTimeout(() => notif.classList.remove('show'), 3000);
        }, index * 3500);
    });
}

// ==================== 统计面板 ====================
let statistics = {};

async function loadStatistics() {
    const result = await apiRequest('statistics');
    if (result && result.success) {
        statistics = result.statistics;
        if (result.newAchievements && result.newAchievements.length > 0) {
            showAchievementNotification(result.newAchievements);
        }
    }
}

